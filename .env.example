DATABASE_URL=postgresql://postgres:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_server_key_here
# Legacy fallback if you still use service_role:
SUPABASE_SERVICE_ROLE_KEY=
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-with-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
AUTH_REFRESH_COOKIE_NAME=swim_flow_refresh_token
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/api/auth
AUTH_SECURE_COOKIES=false
API_CORS_ORIGIN=http://localhost:8080
NEST_API_PORT=3334
CACHE_TTL_SECONDS=30
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

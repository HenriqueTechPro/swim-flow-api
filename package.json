{
    "name":  "swim-flow-api",
    "version":  "0.0.1",
    "description":  "",
    "author":  "",
    "private":  true,
    "license":  "UNLICENSED",
    "scripts":  {
                    "prisma:generate":  "node ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
                    "prisma:migrate:dev":  "node ./node_modules/prisma/build/index.js migrate dev --schema prisma/schema.prisma",
                    "prisma:migrate:deploy":  "node ./node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
                    "build":  "npm run prisma:generate && nest build",
                    "format":  "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
                    "start":  "npm run prisma:generate && nest start",
                    "start:dev":  "nest start --watch",
                    "start:debug":  "nest start --debug --watch",
                    "start:prod":  "npm run prisma:generate && node dist/main.js",
                    "lint":  "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
                    "test":  "jest",
                    "test:watch":  "jest --watch",
                    "test:cov":  "jest --coverage",
                    "test:unit":  "jest --runInBand",
                    "test:debug":  "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
                    "test:e2e":  "jest --config ./test/jest-e2e.json --runInBand",
                    "test:all":  "npm run test:unit \u0026\u0026 npm run test:e2e"
                },
    "dependencies":  {
                         "@nestjs/core":  "^11.0.1",
                         "bcryptjs":  "^2.4.3",
                         "@nestjs/common":  "^11.0.1",
                         "@nestjs/platform-express":  "^11.0.1",
                         "@supabase/supabase-js":  "^2.98.0",
                         "@prisma/client":  "^6.19.3",
                         "zod":  "^3.25.76",
                         "@nestjs/swagger":  "^11.2.0",
                         "express":  "^5.1.0",
                         "reflect-metadata":  "^0.2.2",
                         "rxjs":  "^7.8.1",
                         "swagger-ui-express":  "^5.0.1"
                     },
    "devDependencies":  {
                            "@types/jest":  "^30.0.0",
                            "eslint":  "^9.18.0",
                            "supertest":  "^7.0.0",
                            "prisma":  "^6.19.3",
                            "ts-loader":  "^9.5.2",
                            "@types/express":  "^5.0.0",
                            "typescript":  "^5.7.3",
                            "@types/supertest":  "^7.0.0",
                            "@nestjs/schematics":  "^11.0.0",
                            "typescript-eslint":  "^8.20.0",
                            "ts-jest":  "^29.2.5",
                            "eslint-plugin-prettier":  "^5.2.2",
                            "@nestjs/testing":  "^11.0.1",
                            "jest":  "^30.0.0",
                            "source-map-support":  "^0.5.21",
                            "@types/node":  "^24.0.0",
                            "ts-node":  "^10.9.2",
                            "eslint-config-prettier":  "^10.0.1",
                            "globals":  "^17.0.0",
                            "tsconfig-paths":  "^4.2.0",
                            "@nestjs/cli":  "^11.0.0",
                            "@eslint/eslintrc":  "^3.2.0",
                            "@eslint/js":  "^9.18.0",
                            "prettier":  "^3.4.2"
                        },
    "jest":  {
                 "moduleFileExtensions":  [
                                              "js",
                                              "json",
                                              "ts"
                                          ],
                 "rootDir":  ".",
                 "testRegex":  "(/src/.*|/test/.*)\\.spec\\.ts$",
                 "transform":  {
                                   "^.+\\.(t|j)s$":  "ts-jest"
                               },
                 "collectCoverageFrom":  [
                                             "src/**/*.(t|j)s"
                                         ],
                 "coverageDirectory":  "./coverage",
                 "testEnvironment":  "node",
                 "moduleNameMapper":  {
                                          "^@/(.*)$":  "\u003crootDir\u003e/src/$1"
                                      }
             }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  user
  teacher
  admin

  @@map("app_role")
}

enum Gender {
  Masculino
  Feminino
  Outro

  @@map("gender")
}

enum EntityStatus {
  Ativo
  Licenca @map("LicenÃ§a")
  Inativo

  @@map("entity_status")
}

enum EntityStatusActive {
  Ativo
  Inativo

  @@map("entity_status_active")
}

enum SwimmingCategory {
  Pre_Mirim  @map("PrÃ©-Mirim")
  Mirim_1    @map("Mirim 1")
  Mirim_2    @map("Mirim 2")
  Petiz_1    @map("Petiz 1")
  Petiz_2    @map("Petiz 2")
  Infantil_1 @map("Infantil 1")
  Infantil_2 @map("Infantil 2")
  Juvenil_1  @map("Juvenil 1")
  Juvenil_2  @map("Juvenil 2")
  Junior_1   @map("JÃºnior 1")
  Junior_2   @map("JÃºnior 2")
  Senior     @map("Senior")
  Pre_Master @map("PrÃ©-Master")
  Master_A   @map("Master A")
  Master_B   @map("Master B")
  Master_C   @map("Master C")
  Master_D   @map("Master D")
  Master_E   @map("Master E")
  Master_F   @map("Master F")
  Master_G   @map("Master G")
  Master_H   @map("Master H")
  Master_I   @map("Master I")
  Master_J   @map("Master J")
  Master_K   @map("Master K")
  Master_L   @map("Master L")
  Master_M   @map("Master M")
  Master_N   @map("Master N")
  Master_O   @map("Master O")

  @@map("swimming_category")
}

enum CoachRole {
  head_coach
  assistant_coach

  @@map("coach_role")
}

enum ClassStatus {
  Ativa
  Pausada
  Encerrada

  @@map("class_status")
}

enum EventStatus {
  Agendado
  Em_Andamento @map("Em Andamento")
  Concluido    @map("ConcluÃ­do")
  Cancelado

  @@map("event_status")
}

enum TipoEvento {
  Competicao @map("CompetiÃ§Ã£o")
  Reuniao    @map("ReuniÃ£o")
  Festival
  Outro

  @@map("tipo_evento")
}

enum PoolStatus {
  Ativa
  Pausada
  Encerrada

  @@map("pool_status")
}

enum TipoTreino {
  Tecnico     @map("TÃ©cnico")
  Resistencia @map("ResistÃªncia")
  Velocidade
  Misto

  @@map("tipo_treino")
}

enum NivelTreino {
  Iniciante
  Intermediario @map("IntermediÃ¡rio")
  Avancado      @map("AvanÃ§ado")
  Todos

  @@map("nivel_treino")
}

enum TrainingStatus {
  Ativo
  Pausado
  Encerrado

  @@map("training_status")
}

enum AttendanceStatus {
  present
  absent
  late
  justified

  @@map("attendance_status")
}

enum SwimmingStyle {
  Livre
  Costas
  Peito
  Borboleta

  @@map("swimming_style")
}

enum SwimmingDistance {
  D25m  @map("25m")
  D50m  @map("50m")
  D100m @map("100m")
  D200m @map("200m")

  @@map("swimming_distance")
}

model Profile {
  id        String   @id @db.Uuid
  fullName  String   @default("") @map("full_name")
  avatarUrl String?  @map("avatar_url")
  role      AppRole  @default(user)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("profiles")
}

model Category {
  id                String            @id @default(uuid()) @db.Uuid
  name              SwimmingCategory  @unique
  ageMin            Int?              @map("age_min")
  ageMax            Int?              @map("age_max")
  sortOrder         Int               @default(0) @map("sort_order")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  students          Student[]
  teacherCategories TeacherCategory[]
  swimmingClasses   SwimmingClass[]
  classCategories   ClassCategory[]

  @@map("categories")
}

model Level {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  students    Student[]

  @@map("levels")
}

model Parent {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  photo            String?
  cpf              String?
  birthDate        DateTime?          @map("birth_date") @db.Date
  phone            String             @default("")
  email            String             @default("")
  profession       String             @default("")
  address          String             @default("")
  emergencyContact String             @default("") @map("emergency_contact")
  emergencyPhone   String             @default("") @map("emergency_phone")
  status           EntityStatusActive @default(Ativo)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  exStudents       ExStudent[]
  students         Student[]

  @@map("parents")
}

model Result {
  id              String    @id @default(uuid()) @db.Uuid
  studentId       String    @map("student_id") @db.Uuid
  discipline      String    @default("Piscina")
  style           String
  distance        String
  customDistance  String    @default("") @map("custom_distance")
  competitionType String    @default("") @map("competition_type")
  courseType      String    @default("") @map("course_type")
  eventFormat     String    @default("Prova Individual") @map("event_format")
  time            String
  timeInSeconds   Decimal   @map("time_in_seconds") @db.Decimal
  date            DateTime? @db.Date
  competition     String    @default("")
  position        Int       @default(0)
  resultStatus    String    @default("Classificado") @map("result_status")
  personalBest    Boolean   @default(false) @map("personal_best")
  improvement     Decimal   @default(0) @db.Decimal
  category        String    @default("")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  student         Student   @relation(fields: [studentId], references: [id])

  @@map("results")
  @@index([studentId, date])
  @@index([date, competition])
}
model ExStudent {
  id                  String    @id @default(uuid()) @db.Uuid
  studentId           String?   @map("student_id") @db.Uuid
  name                String
  category            String
  categorySnapshot    String?   @map("category_snapshot")
  exitDate            String    @map("exit_date")
  exitDateAt          DateTime? @map("exit_date_at") @db.Date
  exitReason          String    @map("exit_reason")
  exitReasonCode      String?   @map("exit_reason_code")
  exitNotes           String?   @map("exit_notes")
  phone               String    @default("")
  responsible         String    @default("")
  responsibleSnapshot String?   @map("responsible_snapshot")
  parentId            String?   @map("parent_id") @db.Uuid
  achievements        Int       @default(0)
  lastCompetition     String    @default("") @map("last_competition")
  birthYear           Int       @map("birth_year")
  birthDate           DateTime? @map("birth_date") @db.Date
  level               String    @default("")
  levelSnapshot       String?   @map("level_snapshot")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  student             Student?  @relation(fields: [studentId], references: [id])
  parent              Parent?   @relation(fields: [parentId], references: [id])

  @@map("ex_students")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  description String      @default("")
  type        TipoEvento
  date        DateTime?   @db.Date
  startTime   DateTime    @map("start_time") @db.Time(6)
  endTime     DateTime    @map("end_time") @db.Time(6)
  location    String      @default("")
  status      EventStatus @default(Agendado)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([date, status])
  @@map("events")
}

model Teacher {
  id                    String                 @id @default(uuid()) @db.Uuid
  name                  String
  photo                 String?
  speciality            String                 @default("")
  experience            Int                    @default(0)
  phone                 String                 @default("")
  email                 String                 @default("")
  status                EntityStatus           @default(Ativo)
  birthDate             DateTime?              @map("birth_date") @db.Date
  address               String?
  bio                   String?
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  cpf                   String?
  teacherCategories     TeacherCategory[]
  teacherCertifications TeacherCertification[]
  classTeachers         ClassTeacher[]
  trainings             Training[]

  @@map("teachers")
}

model Student {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  gender            Gender             @default(Masculino)
  birthDate         DateTime?          @map("birth_date") @db.Date
  categoryId        String             @map("category_id") @db.Uuid
  levelId           String             @map("level_id") @db.Uuid
  parentId          String?            @map("parent_id") @db.Uuid
  phone             String             @default("")
  status            EntityStatus       @default(Ativo)
  achievements      Int                @default(0)
  photo             String?
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  categoryLabel     String?            @map("category")
  levelLabel        String?            @map("level")
  lastCompetition   String             @default("") @map("last_competition")
  category          Category           @relation(fields: [categoryId], references: [id])
  level             Level              @relation(fields: [levelId], references: [id])
  parent            Parent?            @relation(fields: [parentId], references: [id])
  exStudents        ExStudent[]
  results           Result[]
  studentClasses    StudentClass[]
  attendanceRecords AttendanceRecord[]

  @@index([categoryId, levelId])
  @@index([parentId])
  @@index([status, createdAt])
  @@map("students")
}

model SwimmingClass {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  categoryId        String             @map("category_id") @db.Uuid
  maxStudents       Int                @default(10) @map("max_students")
  poolId            String?            @map("pool_id") @db.Uuid
  status            ClassStatus        @default(Ativa)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  category          Category           @relation(fields: [categoryId], references: [id])
  pool              Pool?              @relation(fields: [poolId], references: [id])
  studentClasses    StudentClass[]
  classTeachers     ClassTeacher[]
  classSchedules    ClassSchedule[]
  classCategories   ClassCategory[]
  attendanceRecords AttendanceRecord[]

  @@map("classes")
}

model AttendanceRecord {
  id            String           @id @default(uuid()) @db.Uuid
  studentId     String           @map("student_id") @db.Uuid
  classId       String           @map("class_id") @db.Uuid
  date          DateTime         @db.Date
  status        AttendanceStatus
  observations  String           @default("")
  savedAt       DateTime?        @map("saved_at") @db.Timestamptz(6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  student       Student          @relation(fields: [studentId], references: [id])
  swimmingClass SwimmingClass    @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([classId, date])
  @@index([studentId, date])
  @@index([createdAt])
  @@map("attendance_records")
}

model StudentClass {
  id            String        @id @default(uuid()) @db.Uuid
  studentId     String        @map("student_id") @db.Uuid
  classId       String        @map("class_id") @db.Uuid
  isPrimary     Boolean       @default(false) @map("is_primary")
  fromDate      DateTime?     @map("from_date") @db.Date
  toDate        DateTime?     @map("to_date") @db.Date
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  student       Student       @relation(fields: [studentId], references: [id])
  swimmingClass SwimmingClass @relation(fields: [classId], references: [id])

  @@index([studentId, toDate])
  @@index([classId, toDate])
  @@index([studentId, classId, toDate])
  @@map("student_classes")
}

model Pool {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  lengthMeters    Int             @default(25) @map("length_meters")
  address         String          @default("")
  status          PoolStatus      @default(Ativa)
  maxCapacity     Int?            @map("max_capacity")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  swimmingClasses SwimmingClass[]
  trainings       Training[]

  @@index([status, name])
  @@map("pools")
}

model Training {
  id                  String         @id @default(uuid()) @db.Uuid
  title               String
  description         String         @default("")
  type                TipoTreino
  dayOfWeek           String         @map("day_of_week")
  startTime           DateTime       @map("start_time") @db.Time(6)
  endTime             DateTime       @map("end_time") @db.Time(6)
  instructorId        String?        @map("instructor_id") @db.Uuid
  level               NivelTreino    @default(Iniciante)
  maxParticipants     Int            @default(0) @map("max_participants")
  currentParticipants Int            @default(0) @map("current_participants")
  status              TrainingStatus @default(Ativo)
  poolId              String?        @map("pool_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  instructor          Teacher?       @relation(fields: [instructorId], references: [id])
  pool                Pool?          @relation(fields: [poolId], references: [id])

  @@index([instructorId, dayOfWeek])
  @@index([poolId, dayOfWeek])
  @@index([status, level])
  @@map("trainings")
}

model TeacherCategory {
  id         String   @id @default(uuid()) @db.Uuid
  teacherId  String   @map("teacher_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@map("teacher_categories")
}

model ClassCategory {
  id            String        @id @default(uuid()) @db.Uuid
  classId       String        @map("class_id") @db.Uuid
  categoryId    String        @map("category_id") @db.Uuid
  isPrimary     Boolean       @default(false) @map("is_primary")
  swimmingClass SwimmingClass @relation(fields: [classId], references: [id])
  category      Category      @relation(fields: [categoryId], references: [id])

  @@map("class_categories")
}

model ClassSchedule {
  id            String        @id @default(uuid()) @db.Uuid
  classId       String        @map("class_id") @db.Uuid
  dayOfWeek     String        @map("day_of_week")
  startTime     DateTime      @map("start_time") @db.Time(6)
  endTime       DateTime      @map("end_time") @db.Time(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  swimmingClass SwimmingClass @relation(fields: [classId], references: [id])

  @@map("class_schedules")
}

model TeacherCertification {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  teacher   Teacher  @relation(fields: [teacherId], references: [id])

  @@map("teacher_certifications")
}

model ClassTeacher {
  id            String        @id @default(uuid()) @db.Uuid
  classId       String        @map("class_id") @db.Uuid
  teacherId     String        @map("teacher_id") @db.Uuid
  role          CoachRole     @default(assistant_coach)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  swimmingClass SwimmingClass @relation(fields: [classId], references: [id])
  teacher       Teacher       @relation(fields: [teacherId], references: [id])

  @@index([classId, role])
  @@index([teacherId])
  @@map("class_teachers")
}
